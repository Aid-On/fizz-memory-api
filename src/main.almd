// CLI エントリポイント — memory 操作の HTTP サーバ。
//
//   POST /note            本文に MemoryEvent (JSON) → 追記。{"ok":true,"id":N}
//   GET  /recall?user_id=N&limit=M  → {"user_id":N,"events":[...]}
//   GET  /search?q=...    → {"q":"...","events":[...]}
//   POST /wipe            → {"ok":true}
//   GET  /users           → {"users":[id,...]}
//
// 実体のイベントログは l2 と同じ append-only JSONL (FIZZ_MEMORY_PATH、既定
// "memory.jsonl")。ハンドラはリクエストごとにファイルを読み直す stateless 実装。
// ポートは FIZZ_MEMORY_PORT (既定 8088)。
//
// ディスパッチ表 (route) とフィルタ/集計ロジックは mod.almd (transport 非依存)。

import self as api
import fizz_protocol.memory
import http
import fs
import env
import json
import value
import result
import list
import string
import map
import int

local fn events_json(evs: List[memory.MemoryEvent]) -> Value =
  value.array(list.map(evs, (e) => memory.event_encode(e)))

// ファイルから全イベントを読む (無ければ空)。壊れた行は読み飛ばす。
effect fn load_all(path: String) -> Result[List[memory.MemoryEvent], String] = {
  let empty: List[memory.MemoryEvent] = []
  if fs.exists(path) then {
    let lines = fs.read_lines(path)!
    ok(list.filter_map(lines, (ln) => result.to_option(memory.event_decode(json.parse(ln) ?? value.null()))))
  } else {
    ok(empty)
  }
}

effect fn handle_note(file: String, body: String) -> Result[HttpResponse, String] = {
  match memory.event_decode(json.parse(body) ?? value.null()) {
    err(e) => ok(http.response(400, json.stringify(value.object([("error", value.str("bad event: ${e}"))])))),
    ok(ev) => {
      let all = load_all(file)!
      let id = if ev.id > 0 then ev.id else api.next_id(all)
      let stored = memory.MemoryEvent {
        id: id, user_id: ev.user_id, session_id: ev.session_id,
        role: ev.role, content: ev.content, ts: ev.ts, tags: ev.tags,
      }
      fs.append(file, json.stringify(memory.event_encode(stored)) + "\n")!
      ok(http.json(200, json.stringify(value.object([
        ("ok", value.bool(true)), ("id", value.int(id)),
      ]))))
    },
  }
}

effect fn handle_recall(file: String, req: HttpRequest) -> Result[HttpResponse, String] = {
  let params = http.query_params(req)
  let uid = match int.parse(map.get_or(params, "user_id", "0")) { ok(n) => n, err(_) => 0 }
  let limit = match int.parse(map.get_or(params, "limit", "0")) { ok(n) => n, err(_) => 0 }
  let all = load_all(file)!
  ok(http.json(200, json.stringify(value.object([
    ("user_id", value.int(uid)), ("events", events_json(api.recent_of(all, uid, limit))),
  ]))))
}

effect fn handle_search(file: String, req: HttpRequest) -> Result[HttpResponse, String] = {
  let params = http.query_params(req)
  // query_params は URL デコードしない (almide#684) ので自前で復号する。
  let q = api.url_decode(map.get_or(params, "q", ""))
  let all = load_all(file)!
  ok(http.json(200, json.stringify(value.object([
    ("q", value.str(q)), ("events", events_json(api.search(all, q))),
  ]))))
}

effect fn handle_wipe(file: String) -> Result[HttpResponse, String] = {
  if fs.exists(file) then { fs.remove(file)! } else { () }
  ok(http.json(200, "{\"ok\":true}"))
}

effect fn handle_users(file: String) -> Result[HttpResponse, String] = {
  let all = load_all(file)!
  ok(http.json(200, json.stringify(value.object([
    ("users", value.array(list.map(api.distinct_users(all), (id) => value.int(id)))),
  ]))))
}

// ログファイルのパスを env から解決する (ハンドラはローカルを捕獲しない設計)。
effect fn current_file() -> String = {
  let p = string.trim(env.get("FIZZ_MEMORY_PATH") ?? "")
  if p == "" then "memory.jsonl" else p
}

// ハンドラ本体。method+path を mod.route で振り分け、Result を返す。
effect fn dispatch(req: HttpRequest) -> Result[HttpResponse, String] = {
  let file = current_file()
  let method = http.req_method(req)
  let path = api.clean_path(http.req_path(req))
  match api.route(method, path) {
    Note     => handle_note(file, http.req_body(req)),
    Recall   => handle_recall(file, req),
    Search   => handle_search(file, req),
    Wipe     => handle_wipe(file),
    Users    => handle_users(file),
    NotFound => ok(http.response(404, "{\"error\":\"not found\"}")),
  }
}

effect fn main() -> Unit = {
  let port = match int.parse(string.trim(env.get("FIZZ_MEMORY_PORT") ?? "")) {
    ok(n)  => n,
    err(_) => 8088,
  }
  println("[memory-api] listening on http://localhost:${int.to_string(port)} (log: ${current_file()})")
  http.serve(port, (req) => {
    match dispatch(req) {
      ok(resp) => resp,
      err(e)   => http.response(500, json.stringify(value.object([("error", value.str(e))]))),
    }
  })
}
